# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# FIREBASE ADMIN SDK
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Get from: Firebase Console → Project Settings → Service Accounts
# → Generate New Private Key → Download JSON → Extract values

FIREBASE_PROJECT_ID=your_project_id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@project.iam.gserviceaccount.com

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ML ENGINE URL
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# LOCAL DEVELOPMENT:
ML_API_URL=http://localhost:8000

# RAILWAY PRODUCTION (use internal networking - faster & free):
# ML_API_URL=http://rxshield-ml.railway.internal:8000

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# APP CONFIGURATION
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_random_string
NODE_ENV=production
PORT=3000

# Frontend URL for CORS
# LOCAL:
FRONTEND_URL=http://localhost:5173

# VERCEL PRODUCTION:
# FRONTEND_URL=https://your-app.vercel.app
